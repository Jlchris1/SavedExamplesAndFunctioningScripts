local function clearParts(parent, delayTime)
	for _, child in pairs(parent:GetChildren()) do
		clearParts(child, delayTime)
	end

	local cleanupDelay = delayTime
	if cleanupDelay == nil then
		if parent:IsA("Part") then
			cleanupDelay = math.random(5, 10)
		else
			cleanupDelay = 11
		end
	end

	DestroyService:AddItem(parent, cleanupDelay)
end

