local function clearParts(parent)
	for _, child in pairs(parent:GetChildren()) do
		clearParts(child)
	end

	local delayTime
	if parent:IsA("Part") then
		delayTime = math.random(5, 10)
	else
		delayTime = 11
	end

	DestroyService:AddItem(parent, delayTime)
end

local function getPlayerByUserId(userId)
	local ok, result = pcall(function()
		return Players:GetPlayerByUserId(userId)
	end)

	if ok and result then
		return result
	end

	for _, p in ipairs(Players:GetPlayers()) do
		if p.UserId == userId then
			return p
		end
	end

	return nil
end

local function isZombieModel(model)
	if not model then
		return false
	end

	if model:GetAttribute("IsZombie") == true then
		return true
	end

	if model:GetAttribute("ConvertedZombie") == true then
		return true
	end

	if model:GetAttribute("ConvertedPlayerZombie") == true then
		return true
	end

	return string.find(string.lower(model.Name or ""), "zombie", 1, true) ~= nil
end

local function isConvertingModel(model)
	if not model then
		return false
	end
	return model:GetAttribute("ZombieConverting") == true
end

local function getModelRoot(model)
	if not model then
		return nil
	end
	return model.PrimaryPart
		or model:FindFirstChild("HumanoidRootPart")
		or model:FindFirstChild("Torso")
		or model:FindFirstChild("UpperTorso")
		or model:FindFirstChildWhichIsA("BasePart")
end

local function getRootFromCharacter(character)
	return getModelRoot(character)
end

local function setSpeed(speed)
	if humanoid.WalkSpeed ~= speed then
		humanoid.WalkSpeed = speed
	end
end

local function clearCurrentTarget()
	currentTargetPos = nil
	currentTargetModel = nil
	currentTargetHumanoid = nil
	currentTargetKind = nil
	currentTargetMemoryUntil = 0
	lastHeardAt = 0
end

local function resetAttackState()
	attacking = false
	attackEndsAt = 0
end

local function releaseVictim(keepLock)
	if not grabbedVictim then
		return
	end

	local g = grabbedVictim
	grabbedVictim = nil

	if g.model and g.model.Parent and not keepLock then
		g.model:SetAttribute("ZombieGrabLocked", false)
	end

	if g.diedConn then
		pcall(function()
			g.diedConn:Disconnect()
		end)
	end

	if g.weld and g.weld.Parent then
		g.weld:Destroy()
	end

	if g.humanoid and g.humanoid.Parent then
		g.humanoid.PlatformStand = g.saved.PlatformStand
		g.humanoid.AutoRotate = g.saved.AutoRotate
		g.humanoid.WalkSpeed = g.saved.WalkSpeed
		pcall(function()
			g.humanoid.JumpPower = g.saved.JumpPower
		end)
		pcall(function()
			g.humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
		end)
	end

	if g.partCollisions then
		for part, oldValue in pairs(g.partCollisions) do
			if part and part.Parent then
				part.CanCollide = oldValue
			end
		end
	end
end

local function ensureBiteHold()
	if biteHold and biteHold.Parent then
		return biteHold
	end

	biteHold = Instance.new("Part")
	biteHold.Name = "BiteHold"
	biteHold.Size = Vector3.new(1, 1, 1)
	biteHold.Transparency = 1
	biteHold.CanCollide = false
	biteHold.CanQuery = false
	biteHold.CanTouch = false
	biteHold.Massless = true
	biteHold.Anchored = false
	biteHold.Parent = zombie
	biteHold.CFrame = root.CFrame * CFrame.new(0, 0.4, -2.0)

	local weld = Instance.new("WeldConstraint")
	weld.Part0 = root
	weld.Part1 = biteHold
	weld.Parent = biteHold

	return biteHold
end

local function loadAnimator(hum)
	local animator = hum:FindFirstChildOfClass("Animator")
	if not animator then
		animator = Instance.new("Animator")
		animator.Parent = hum
	end
	return animator
end

local function playOneShotAnimation(hum, animId)
	local animator = loadAnimator(hum)
	local anim = Instance.new("Animation")
	anim.AnimationId = animId
	local track = animator:LoadAnimation(anim)
	track.Priority = Enum.AnimationPriority.Action
	track:Play(0)
	return track, anim
end

local function playAttackAnimation()
	pcall(function()
		if attackTrack then
			attackTrack:Stop(0)
			attackTrack:Destroy()
		end
	end)
	attackTrack = playOneShotAnimation(humanoid, "rbxassetid://135030001439615")
end

local function playNpcScream(parentPart)
	if not parentPart or not parentPart.Parent then
		return nil
	end

	local soundId = NPC_SCREAM_SOUND_ID or CONVERT_SOUND_ID

	local scream = Instance.new("Sound")
	scream.Name = "NpcScream"
	scream.SoundId = soundId
	scream.Volume = 1.15
	scream.RollOffMaxDistance = 80
	scream.PlaybackSpeed = 1.1
	scream.Parent = parentPart
	scream:Play()

	task.delay(1.25, function()
		if scream and scream.Parent then
			pcall(function()
				scream:Stop()
				scream:Destroy()
			end)
		end
	end)

	return scream
end

local function colorZombieModel(model)
	for _, desc in ipairs(model:GetDescendants()) do
		if desc:IsA("BasePart") then
			desc.Color = ZOMBIE_GREEN
			desc.Material = Enum.Material.SmoothPlastic
		elseif desc:IsA("BodyColors") then
			pcall(function()
				desc.HeadColor3 = ZOMBIE_GREEN
				desc.LeftArmColor3 = ZOMBIE_GREEN
				desc.RightArmColor3 = ZOMBIE_GREEN
				desc.LeftLegColor3 = ZOMBIE_GREEN
				desc.RightLegColor3 = ZOMBIE_GREEN
				desc.TorsoColor3 = ZOMBIE_GREEN
			end)
		end
	end
end

local function removeCharacterScripts(model)
	for _, desc in ipairs(model:GetDescendants()) do
		if desc:IsA("LocalScript") or desc:IsA("Script") or desc:IsA("ModuleScript") then
			desc:Destroy()
		end
	end
end

local function copyZombieScriptsInto(model)
