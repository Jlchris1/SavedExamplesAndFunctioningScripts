local function cleanupSound(sound)
	activeSounds[sound] = nil

	if soundConnections[sound] then
		for _, conn in ipairs(soundConnections[sound]) do
			pcall(function()
				conn:Disconnect()
			end)
		end
	end

	soundConnections[sound] = nil
end

local function setSoundActive(sound, active)
	if active then
		activeSounds[sound] = true
	else
		activeSounds[sound] = nil
	end
end

local function registerSound(sound)
	if soundConnections[sound] then
		return
	end

	soundConnections[sound] = {}

	local function refresh()
		if sound.Parent and sound:IsDescendantOf(workspace) and sound.IsPlaying then
			setSoundActive(sound, true)
		else
			setSoundActive(sound, false)
		end
	end

	table.insert(soundConnections[sound], sound:GetPropertyChangedSignal("Playing"):Connect(refresh))
	table.insert(soundConnections[sound], sound.AncestryChanged:Connect(function()
		if not sound:IsDescendantOf(workspace) then
			cleanupSound(sound)
		else
			refresh()
		end
	end))

	refresh()
end

local function getSoundSourcePosition(sound)
	local obj = sound.Parent
	while obj do
		if obj:IsA("BasePart") then
			return obj.Position
		elseif obj:IsA("Attachment") then
			return obj.WorldPosition
		elseif obj:IsA("Model") then
			local mr = getModelRoot(obj)
			if mr then
				return mr.Position
			end
		elseif obj:IsA("Tool") then
			local handle = obj:FindFirstChild("Handle")
			if handle and handle:IsA("BasePart") then
				return handle.Position
			end
		end
		obj = obj.Parent
	end
	return nil
end

local function getSoundSourceModel(sound)
	local obj = sound.Parent
	while obj do
		if obj:IsA("Model") then
			return obj
		end
		obj = obj.Parent
	end
	return nil
end

local function getSoundEvent(sound)
	if not activeSounds[sound] then
		return nil
	end

	local sourcePos = getSoundSourcePosition(sound)
	if not sourcePos then
		return nil
	end

	local sourceModel = getSoundSourceModel(sound)
	if sourceModel and (isZombieModel(sourceModel) or isConvertingModel(sourceModel)) then
		return nil
	end

	local dist = (root.Position - sourcePos).Magnitude

	local loudness = 0
	pcall(function()
		loudness = sound.PlaybackLoudness or 0
	end)

	local score = (sound.Volume or 0) * 20 + loudness / 8

	local name = string.lower(sound.Name or "")
	local triggerRadius = DEFAULT_SOUND_TRIGGER_RADIUS
	local alertRadius = DEFAULT_SOUND_ALERT_RADIUS

	if name:find("walk") or name:find("step") or name:find("run") or name:find("foot") then
		triggerRadius = WALK_SOUND_TRIGGER_RADIUS
		alertRadius = WALK_SOUND_ALERT_RADIUS
	elseif name:find("jump") or name:find("land") or name:find("fall") then
		triggerRadius = JUMP_SOUND_TRIGGER_RADIUS
		alertRadius = JUMP_SOUND_ALERT_RADIUS
	end

	if name:find("gun") or name:find("shoot") or name:find("boom") or name:find("blast") or name:find("explosion") then
		triggerRadius = math.max(triggerRadius, 60)
		alertRadius = math.max(alertRadius, 90)
	end

	if dist > alertRadius then
		return nil
	end

	local memoryUntil = time() + 2.5
	if score >= 70 then
		memoryUntil = time() + FAR_SOUND_RUN_TIME
	end

	local sourceHumanoid = nil
	if sourceModel then
		sourceHumanoid = sourceModel:FindFirstChildOfClass("Humanoid")
	end

	return {
		pos = sourcePos,
		dist = dist,
		score = score,
		triggerRadius = triggerRadius,
		alertRadius = alertRadius,
		memoryUntil = memoryUntil,
		kind = "sound",
		model = sourceModel,
		humanoid = sourceHumanoid,
	}
end

workspace.DescendantAdded:Connect(function(obj)
	if obj:IsA("Sound") then
		registerSound(obj)
	end
end)

for _, obj in ipairs(workspace:GetDescendants()) do
	if obj:IsA("Sound") then
		registerSound(obj)
	end
end

--////////////////////////////////////////////////////////////
-- VIBRATIONS
--////////////////////////////////////////////////////////////
local function getVibrationEvents()
	local events = {}

	for _, player in ipairs(Players:GetPlayers()) do
		local character = player.Character
		local humanoidObj = character and character:FindFirstChildOfClass("Humanoid")
		local charRoot = getRootFromCharacter(character)

		if character and humanoidObj and charRoot and humanoidObj.Health > 0 and not isZombieModel(character) and not isConvertingModel(character) then
			local pos = charRoot.Position
			local vel = charRoot.AssemblyLinearVelocity
			local horizontalSpeed = Vector3.new(vel.X, 0, vel.Z).Magnitude
			local stateData = characterState[character] or {
				wasAirborne = false,
				lastYVelocity = 0,
				lastJumpEvent = 0,
				lastRunEvent = 0,
				lastLandingEvent = 0,
			}

			local now = time()
			local inAir = humanoidObj.FloorMaterial == Enum.Material.Air
				or humanoidObj:GetState() == Enum.HumanoidStateType.Freefall
				or humanoidObj:GetState() == Enum.HumanoidStateType.Jumping

			if horizontalSpeed >= 14 and (now - stateData.lastRunEvent) >= 0.15 then
				table.insert(events, {
					pos = pos,
					dist = 0,
					score = 40 + horizontalSpeed,
					triggerRadius = RUN_VIB_TRIGGER_RADIUS,
					alertRadius = RUN_VIB_ALERT_RADIUS,
					memoryUntil = now + 1.5,
					kind = "run",
					model = character,
					humanoid = humanoidObj,
				})
				stateData.lastRunEvent = now
			end

			if inAir and (now - stateData.lastJumpEvent) >= 0.2 then
				table.insert(events, {
					pos = pos,
					dist = 0,
					score = 20 + math.abs(vel.Y),
					triggerRadius = AIR_VIB_TRIGGER_RADIUS,
					alertRadius = AIR_VIB_ALERT_RADIUS,
					memoryUntil = now + 1.5,
					kind = "air",
					model = character,
					humanoid = humanoidObj,
				})
				stateData.lastJumpEvent = now
				stateData.wasAirborne = true
				stateData.lastYVelocity = vel.Y
			end

			if stateData.wasAirborne and not inAir then
				if (now - stateData.lastLandingEvent) >= 0.25 then
					table.insert(events, {
						pos = pos,
						dist = 0,
						score = 50 + math.abs(stateData.lastYVelocity or 0),
						triggerRadius = AIR_VIB_TRIGGER_RADIUS,
						alertRadius = AIR_VIB_ALERT_RADIUS,
						memoryUntil = now + 2,
						kind = "land",
						model = character,
						humanoid = humanoidObj,
					})
					stateData.lastLandingEvent = now
				end

				stateData.wasAirborne = false
			end

			stateData.lastYVelocity = vel.Y
			characterState[character] = stateData
		end
	end

	return events
end

--////////////////////////////////////////////////////////////
-- TARGETING
--////////////////////////////////////////////////////////////
local function refreshCurrentTargetPosition()
	if currentTargetModel and currentTargetModel.Parent then
		if currentTargetModel:GetAttribute("ZombieConverting") == true then
			clearCurrentTarget()
			return
		end

		local mr = getModelRoot(currentTargetModel)
		if mr then
			currentTargetPos = mr.Position
		else
			clearCurrentTarget()
		end
	end
end

local function pickBestEvent()
	local best = nil
	local bestScore = -math.huge

	for sound in pairs(activeSounds) do
		if not sound.Parent or not sound:IsDescendantOf(workspace) then
			cleanupSound(sound)
		else
			local ev = getSoundEvent(sound)
			if ev then
				if ev.dist <= ev.triggerRadius then
					ev.score += 1000
				else
					ev.score += 500
				end

				if ev.score > bestScore then
					bestScore = ev.score
					best = ev
				end
			end
		end
	end

	for _, ev in ipairs(getVibrationEvents()) do
		if ev.dist <= ev.triggerRadius then
			ev.score += 1000
		elseif ev.dist <= ev.alertRadius then
			ev.score += 500
		else
			ev = nil
		end

		if ev and ev.score > bestScore then
			bestScore = ev.score
			best = ev
		end
	end

	return best
end

local function startLookAround(now)
	state = "Look"
	clearCurrentTarget()
	currentTargetEndsAt = now + LOOK_AROUND_TIME
	wanderGoal = nil
	setSpeed(0)
end

local function startWander(now)
	state = "Wander"
	clearCurrentTarget()
	currentTargetEndsAt = now + WANDER_TIME
	setSpeed(WALK_SPEED)

	local angle = math.random() * math.pi * 2
	local dist = math.random(18, 35)
	wanderGoal = root.Position + Vector3.new(math.cos(angle) * dist, 0, math.sin(angle) * dist)
end

local function tryAttackCurrentTarget()
	if not currentTargetHumanoid or not currentTargetModel then
		return false
	end

	if isZombieModel(currentTargetModel) then
		return false
	end

	if currentTargetModel:GetAttribute("ZombieGrabLocked") == true then
		return false
	end

	if currentTargetModel:GetAttribute("ZombieConverting") == true then
		return false
	end

	local targetRoot = getModelRoot(currentTargetModel)
	if not targetRoot then
		return false
	end

	local dist = (root.Position - targetRoot.Position).Magnitude
	if dist > ATTACK_RANGE then
		return false
	end

	return beginGrab(currentTargetModel, currentTargetHumanoid)
end

--////////////////////////////////////////////////////////////
-- DEATH
--////////////////////////////////////////////////////////////
humanoid.Died:Connect(function()
	cancelAllConversions()
	releaseVictim(false)
	math.randomseed(tick())
	clearParts(zombie)
	script.Disabled = true
end)

--////////////////////////////////////////////////////////////
-- MAIN LOOP
--////////////////////////////////////////////////////////////
humanoid.WalkSpeed = WALK_SPEED
humanoid.AutoRotate = true

while zombie.Parent do
	local now = time()

	if attacking and now >= attackEndsAt then
		resetAttackState()
	end

	refreshCurrentTargetPosition()

	if grabbedVictim then
		state = "Attack"
	end

	if not grabbedVictim then
		local bestEvent = pickBestEvent()
		if bestEvent then
			currentTargetPos = bestEvent.pos
			currentTargetModel = bestEvent.model
			currentTargetHumanoid = bestEvent.humanoid
			currentTargetKind = bestEvent.kind
			currentTargetMemoryUntil = math.max(currentTargetMemoryUntil, bestEvent.memoryUntil or now)
			lastHeardAt = now

			if bestEvent.dist <= bestEvent.triggerRadius then
				state = "Run"
				setSpeed(RUN_SPEED)
			else
				state = "Alert"
				setSpeed(ALERT_SPEED)
			end
		elseif now > currentTargetMemoryUntil then
			clearCurrentTarget()
			if state ~= "Look" and state ~= "Wander" then
				state = "Idle"
				setSpeed(0)
			end
		end
	end

	if state == "Attack" then
		setSpeed(0)
		humanoid:MoveTo(root.Position)

		if now >= attackEndsAt then
			resetAttackState()
			releaseVictim(false)

			if currentTargetModel and currentTargetModel.Parent and currentTargetHumanoid and currentTargetHumanoid.Health > 0 then
				refreshCurrentTargetPosition()
				if currentTargetPos then
					local dist = (root.Position - currentTargetPos).Magnitude
					if dist <= 12 then
						state = "Run"
						setSpeed(RUN_SPEED)
					else
						state = "Alert"
						setSpeed(ALERT_SPEED)
					end
				else
					state = "Idle"
					setSpeed(0)
				end
			else
				state = "Idle"
				setSpeed(0)
			end
		end

	elseif state == "Run" or state == "Alert" then
		if currentTargetPos then
			humanoid:MoveTo(currentTargetPos)

			local distToTarget = (root.Position - currentTargetPos).Magnitude
			local sourceStillFresh = (now - lastHeardAt) <= 1.5

			if not grabbedVictim then
				if currentTargetHumanoid and currentTargetHumanoid.Health > 0 and distToTarget <= ATTACK_RANGE then
					if tryAttackCurrentTarget() then
						task.wait(0.05)
						continue
					end
				end
			end

			if distToTarget <= ARRIVE_DISTANCE and not sourceStillFresh and now > currentTargetMemoryUntil then
				startLookAround(now)
			end
		else
			if now > currentTargetMemoryUntil then
				state = "Idle"
				setSpeed(0)
			end
		end

		if state == "Run" and now >= currentTargetMemoryUntil then
			state = "Alert"
			setSpeed(ALERT_SPEED)
		end

	elseif state == "Look" then
		setSpeed(0)
		humanoid:MoveTo(root.Position)

		if now >= currentTargetEndsAt then
			startWander(now)
		end

	elseif state == "Wander" then
		setSpeed(WALK_SPEED)

		if wanderGoal then
			humanoid:MoveTo(wanderGoal)
			if (root.Position - wanderGoal).Magnitude <= ARRIVE_DISTANCE or now >= currentTargetEndsAt then
				state = "Idle"
				wanderGoal = nil
				setSpeed(0)
			end
		else
			state = "Idle"
			setSpeed(0)
		end
	end

	task.wait(0.15)
end
