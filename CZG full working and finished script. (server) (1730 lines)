local function setupMovementAnimationController(model, hum)
	local animator = loadAnimator(hum)

	local controller = {
		rigType = hum.RigType,
		current = nil,
		tracks = {},
		anims = {},
	}

	local function loadTrack(id, priority, looped)
		local anim = Instance.new("Animation")
		anim.AnimationId = id
		local track = animator:LoadAnimation(anim)
		track.Priority = priority
		track.Looped = looped == true
		return track, anim
	end

	local function stopTrack(track)
		if track then
			pcall(function()
				track:Stop(0.1)
			end)
		end
	end

	local function stopAll()
		for _, track in pairs(controller.tracks) do
			stopTrack(track)
		end
	end

	controller.stopAll = stopAll

	if hum.RigType == Enum.HumanoidRigType.R6 then
		local walkTrack, walkAnim = loadTrack(R6_NORMAL_WALK_ANIM_ID, Enum.AnimationPriority.Movement, true)
		local alertTrack, alertAnim = loadTrack(R6_ALERT_ANIM_ID, Enum.AnimationPriority.Action, true)
		local triggeredTrack, triggeredAnim = loadTrack(R6_TRIGGERED_ANIM_ID, Enum.AnimationPriority.Action, true)

		controller.tracks.walk = walkTrack
		controller.tracks.alert = alertTrack
		controller.tracks.triggered = triggeredTrack
		controller.anims.walk = walkAnim
		controller.anims.alert = alertAnim
		controller.anims.triggered = triggeredAnim

		function controller:setState(newState)
			if self.current == newState then
				return
			end
			self.current = newState
			stopAll()

			if newState == "Wander" then
				pcall(function() walkTrack:Play(0.1) end)
			elseif newState == "Alert" then
				pcall(function() alertTrack:Play(0.1) end)
			elseif newState == "Run" or newState == "Attack" then
				pcall(function() triggeredTrack:Play(0.1) end)
			end
		end
	else
		local idleTrack, idleAnim = loadTrack(CLASSIC_R15_IDLE_ANIM_ID, Enum.AnimationPriority.Idle, true)
		local walkTrack, walkAnim = loadTrack(R15_CONVERTED_WANDER_WALK_ANIM_ID, Enum.AnimationPriority.Movement, true)
		local alertTrack, alertAnim = loadTrack(R15_CONVERTED_ALERT_WALK_ANIM_ID, Enum.AnimationPriority.Movement, true)
		local triggeredTrack, triggeredAnim = loadTrack(R15_CONVERTED_TRIGGERED_RUN_ANIM_ID, Enum.AnimationPriority.Action, true)

		controller.tracks.idle = idleTrack
		controller.tracks.walk = walkTrack
		controller.tracks.alert = alertTrack
		controller.tracks.triggered = triggeredTrack
		controller.anims.idle = idleAnim
		controller.anims.walk = walkAnim
		controller.anims.alert = alertAnim
		controller.anims.triggered = triggeredAnim

		function controller:setState(newState)
			if self.current == newState then
				return
			end
			self.current = newState
			stopAll()

			if newState == "Wander" then
				pcall(function() walkTrack:Play(0.1) end)
			elseif newState == "Alert" then
				pcall(function() alertTrack:Play(0.1) end)
			elseif newState == "Run" or newState == "Attack" then
				pcall(function() triggeredTrack:Play(0.1) end)
			else
				pcall(function() idleTrack:Play(0.1) end)
			end
		end
	end

	return controller
end

