local function setupClassicR15MovementAnimations(model, hum)
	local animator = loadAnimator(hum)

	local idleAnim = Instance.new("Animation")
	idleAnim.AnimationId = CLASSIC_R15_IDLE_ANIM_ID

	local walkAnim = Instance.new("Animation")
	walkAnim.AnimationId = CLASSIC_R15_WALK_ANIM_ID

	local idleTrack = animator:LoadAnimation(idleAnim)
	local walkTrack = animator:LoadAnimation(walkAnim)

	idleTrack.Priority = Enum.AnimationPriority.Idle
	walkTrack.Priority = Enum.AnimationPriority.Movement
	idleTrack.Looped = true
	walkTrack.Looped = true

	local function stopTracks()
		pcall(function()
			idleTrack:Stop(0.1)
		end)
		pcall(function()
			walkTrack:Stop(0.1)
		end)
	end

	local function update(speed)
		if not hum.Parent or hum.Health <= 0 then
			stopTracks()
			return
		end

		if speed > 0.5 then
			if not walkTrack.IsPlaying then
				pcall(function() idleTrack:Stop(0.1) end)
				pcall(function() walkTrack:Play(0.1) end)
			end
		else
			if not idleTrack.IsPlaying then
				pcall(function() walkTrack:Stop(0.1) end)
				pcall(function() idleTrack:Play(0.1) end)
			end
		end
	end

	local runningConn = hum.Running:Connect(update)
	local diedConn = hum.Died:Connect(function()
		stopTracks()
	end)

	update(0)

	return {
		idleTrack = idleTrack,
		walkTrack = walkTrack,
		idleAnim = idleAnim,
		walkAnim = walkAnim,
		runningConn = runningConn,
		diedConn = diedConn,
	}
end

