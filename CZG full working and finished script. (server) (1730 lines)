local function pruneSpeedHistory(character, nowTime)
	local history = speedHistory[character]
	if not history then
		return
	end

	while #history > 0 and (nowTime - history[1].t) > SPEED_HISTORY_WINDOW do
		table.remove(history, 1)
	end

	if #history == 0 then
		speedHistory[character] = nil
	end
end

local function recordCharacterSpeed(character, humanoidObj, nowTime)
	if not character or not character.Parent or not humanoidObj or not humanoidObj.Parent then
		return
	end

	local rootPart = getRootFromCharacter(character)
	local moveSpeed = 0
	if rootPart and rootPart:IsA("BasePart") then
		local vel = rootPart.AssemblyLinearVelocity
		moveSpeed = Vector3.new(vel.X, 0, vel.Z).Magnitude
	end

	local effectiveSpeed = math.max(humanoidObj.WalkSpeed or 0, moveSpeed or 0)

	local history = speedHistory[character]
	if not history then
		history = {}
		speedHistory[character] = history
	end

	local lastSample = history[#history]
	if not lastSample
		or math.abs((lastSample.effectiveSpeed or 0) - effectiveSpeed) >= 0.1
		or (nowTime - (lastSample.t or 0)) >= 0.1
	then
		table.insert(history, {
			t = nowTime,
			walkSpeed = humanoidObj.WalkSpeed or 0,
			moveSpeed = moveSpeed,
			effectiveSpeed = effectiveSpeed,
		})
	end

	pruneSpeedHistory(character, nowTime)
end

local function getHistoricalSpeed(character, secondsAgo, fallback)
	local history = speedHistory[character]
	if not history or #history == 0 then
		return fallback
	end

	local targetTime = time() - (secondsAgo or SPEED_RESTORE_OFFSET)

	local bestBefore = nil
	local bestBeforeDt = math.huge
	local bestAny = fallback
	local bestAnyDt = math.huge

	for _, sample in ipairs(history) do
		local sampleSpeed = sample.effectiveSpeed or sample.walkSpeed or sample.moveSpeed or fallback
		local dt = math.abs(sample.t - targetTime)

		if dt < bestAnyDt then
			bestAnyDt = dt
			bestAny = sampleSpeed
		end

		if sample.t <= targetTime and dt < bestBeforeDt then
			bestBeforeDt = dt
			bestBefore = sampleSpeed
		end
	end

	local chosen = bestBefore or bestAny or fallback
	if typeof(chosen) ~= "number" then
		chosen = fallback or WALK_SPEED
	end

	return math.max(0, math.floor(chosen + 0.5))
end

