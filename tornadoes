-- ReplicatedStorage.Modules.CloudManager
local CloudManager = {}
local RunService = game:GetService("RunService")
local Debris = game:GetService("Debris")
local TweenService = game:GetService("TweenService")
local Config = require(game.ReplicatedStorage.Modules.Config)

local CLOUD_TAG = "WeatherCloudBlob"
local activeClouds = {}

-- Helper: create a particle-emitter part
local function makeEmitterPart(parentModel, texture, sizeScale)
    local p = Instance.new("Part")
    p.Name = "EmitterPart"
    p.Size = Vector3.new(1,1,1) * math.clamp(sizeScale*0.08, 0.2, 3)
    p.Anchored = true
    p.CanCollide = false
    p.Transparency = 1
    p.Parent = parentModel

    local att = Instance.new("Attachment")
    att.Name = "EmitterAttachment"
    att.Parent = p

    local emitter = Instance.new("ParticleEmitter")
    emitter.Name = "SmokeEmitter"
    emitter.Texture = texture or Config.SmokeTexture
    emitter.Rate = 70 * math.clamp(sizeScale/12, 0.6, 2.5)
    emitter.Lifetime = NumberRange.new(2.5, 6.5)
    emitter.Speed = NumberRange.new(0.6, 3.5)
    emitter.Rotation = NumberRange.new(0, 360)
    emitter.RotSpeed = NumberRange.new(-90, 90)
    emitter.Size = NumberSequence.new{
        NumberSequenceKeypoint.new(0, 0.6 * math.clamp(sizeScale/18, 0.6, 1.8)),
        NumberSequenceKeypoint.new(1, 1.6 * math.clamp(sizeScale/18, 0.6, 1.8))
    }
    emitter.Color = ColorSequence.new(Color3.fromRGB(110,110,110))
    emitter.LightEmission = 0
    emitter.LockedToPart = false
    emitter.Enabled = true
    emitter.Parent = p

    return p, emitter
end

-- Create one cloud model with N orbiting emitter parts.
-- position = Vector3, size = scalar controlling emitter intensity/spacing, emitters = number of emitter nodes
function CloudManager.SpawnCloud(position, size, emitters)
    size = size or math.random(Config.CloudMinSize, Config.CloudMaxSize)
    emitters = emitters or math.clamp(math.floor(size/6), 4, 12)

    -- Create container model
    local model = Instance.new("Model")
    model.Name = "CloudBlob"
    model.Parent = workspace

    -- center part (anchored, invisible) to store position
    local center = Instance.new("Part")
    center.Name = "Center"
    center.Size = Vector3.new(1,1,1)
    center.CFrame = CFrame.new(position)
    center.Anchored = true
    center.CanCollide = false
    center.Transparency = 1
    center.Parent = model

    -- build emitter parts in a ring
    local nodes = {}
    local baseRadius = math.clamp(size * 0.5, 4, 60)

    for i = 1, emitters do
        local node, emitter = makeEmitterPart(model, Config.SmokeTexture, size)
        -- initial placement in ring around center
        local angle = (i / emitters) * math.pi * 2
        local x = math.cos(angle) * (baseRadius * (0.6 + math.random()*0.6))
        local z = math.sin(angle) * (baseRadius * (0.6 + math.random()*0.6))
        local y = position.Y + math.random(-3, 6)
        node.CFrame = CFrame.new(position + Vector3.new(x, y - position.Y, z))
        nodes[i] = {part = node, angle = angle, radius = (node.Position - position).Magnitude, heightOffset = node.Position.Y - position.Y}
    end

    -- tag for easy queries
    pcall(function() game:GetService("CollectionService"):AddTag(model, CLOUD_TAG) end)

    -- orbit / drift behavior using RunService
    local spinSpeed = 0.6 + math.random() * 1.6 -- radians per second
    local driftVelocity = Vector3.new((math.random()-0.5)*0.8, (math.random()-0.1)*0.2, (math.random()-0.5)*0.8)
    local alive = true

    local connection
    connection = RunService.Heartbeat:Connect(function(dt)
        if not alive then
            connection:Disconnect()
            return
        end

        -- gentle center drift
        local cpos = center.Position + driftVelocity * dt
        center.CFrame = CFrame.new(cpos)

        -- update each node position to orbit center (creates swirling visual)
        for idx, info in ipairs(nodes) do
            info.angle = info.angle + (spinSpeed * (0.6 + (idx%3)*0.12)) * dt
            local r = info.radius * (0.95 + 0.1*math.sin(tick()*0.2 + idx))
            local x = math.cos(info.angle) * r
            local z = math.sin(info.angle) * r
            local y = cpos.Y + info.heightOffset + math.sin(tick()*0.3 + idx) * 0.6
            local newCFrame = CFrame.new(cpos + Vector3.new(x, y - cpos.Y, z))
            -- smooth move
            info.part.CFrame = info.part.CFrame:Lerp(newCFrame, math.clamp(10*dt, 0, 1))
        end
    end)

    -- auto-cleanup after lifetime (Debris will remove model and also disconnect heartbeat)
    Debris:AddItem(model, Config.CloudLifetime or 600)

    -- store minimal handle
    activeClouds[#activeClouds+1] = {model = model, alive = true}
    return model
end

-- Simple merge pass (optional, keep for compatibility)
function CloudManager.MergeNearby()
    local CollectionService = game:GetService("CollectionService")
    local blobs = workspace:GetTagged(CLOUD_TAG)
    for i = 1, #blobs do
        local a = blobs[i]
        if not a or not a.Parent then continue end
        for j = i+1, #blobs do
            local b = blobs[j]
            if not b or not b.Parent then continue end
            local dist = (a.PrimaryPart and a.PrimaryPart.Position or a:GetModelCFrame().p) - (b.PrimaryPart and b.PrimaryPart.Position or b:GetModelCFrame().p)
            if dist.Magnitude < 10 then
                -- simple merge: destroy smaller and slightly enlarge bigger
                if a:GetExtentsSize().Magnitude >= b:GetExtentsSize().Magnitude then
                    b:Destroy()
                else
                    a:Destroy()
                end
            end
        end
    end
end

-- Start optional continuous spawner/movement (you can still call CloudManager.SpawnCloud manually)
function CloudManager.Start()
    -- nothing to start here specifically; CloudSpawner will call SpawnCloud periodically.
    -- Keep function for backward compatibility.
    return
end

return CloudManager

-- ServerScriptService.CloudSpawner
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CloudManager = require(ReplicatedStorage.Modules.CloudManager)
local Config = require(ReplicatedStorage.Modules.Config)
local RunService = game:GetService("RunService")

local function getMapCenter()
    local centerPart = workspace:FindFirstChild("MapCenter")
    if centerPart and centerPart:IsA("BasePart") then
        return centerPart.Position
    end
    return Vector3.new(0, 60, 0)
end

-- Spawn a single cloud near map center
local function spawnSingleCloud()
    local center = getMapCenter()
    local jitter = Vector3.new(math.random(-300,300), math.random(20,110), math.random(-300,300))
    local pos = center + jitter
    if pos.Y < Config.MinSpawnY then pos = Vector3.new(pos.X, Config.MinSpawnY + 20, pos.Z) end
    local size = math.random(Config.CloudMinSize, Config.CloudMaxSize)
    CloudManager.SpawnCloud(pos, size, math.clamp(math.floor(size/6), 4, 10))
end

-- spawn wall-cloud cluster (denser)
local function spawnWallCloud(centerPos, count, spread, baseSize)
    count = count or math.random(5,9)
    spread = spread or math.clamp(baseSize or 40, 8, 120)
    baseSize = baseSize or math.random(Config.CloudMinSize*2, Config.CloudMaxSize*1.4)
    for i = 1, count do
        local offset = Vector3.new(math.random(-spread,spread), math.random(-8,18), math.random(-spread,spread))
        local pos = centerPos + offset
        CloudManager.SpawnCloud(pos, math.clamp(baseSize * (0.6 + math.random()*0.9), Config.CloudMinSize, Config.CloudMaxSize*1.6),
            math.clamp(math.floor(baseSize/8), 5, 12))
        task.wait(0.06)
    end
end

-- main loop
spawn(function()
    while true do
        -- spawn some singles
        for i = 1, math.random(1,2) do
            if #workspace:GetChildren() >= 0 then -- cheap cap, you can use CollectionService tags for counting instead
                spawnSingleCloud()
            end
