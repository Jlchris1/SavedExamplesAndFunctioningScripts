local function getTemplateName(userId)
	return "ConvertedZombieTemplate_" .. tostring(userId)
end

local function getConvertedPlayerTemplate(userId)
	return templateFolder:FindFirstChild(getTemplateName(userId))
end

local function storeConvertedPlayerTemplate(userId, model)
	local existing = templateFolder:FindFirstChild(getTemplateName(userId))
	if existing then
		return existing
	end

	local oldArchivable = model.Archivable
	model.Archivable = true

	local template = model:Clone()

	model.Archivable = oldArchivable

	if not template then
		return nil
	end

	template.Name = getTemplateName(userId)
	template:SetAttribute("ZombieConverting", nil)
	template:SetAttribute("ZombieGrabLocked", nil)
	template:SetAttribute("IsZombie", nil)
	template:SetAttribute("ConvertedZombie", nil)
	template.Parent = templateFolder
	return template
end

local function getOwningPlayerFromModel(model)
	if not model then
		return nil
	end

	local userId = model:GetAttribute("ConvertedPlayerUserId")
	if typeof(userId) == "number" then
		local p = getPlayerByUserId(userId)
		if p then
			return p
		end
	end

	return Players:GetPlayerFromCharacter(model)
end

local function respawnPlayerCharacterNormally(player)
	if not player or not player.Parent then
		return
	end

	player:SetAttribute("ZombieRespawnLock", true)

	task.defer(function()
		if player and player.Parent then
			pcall(function()
				player:LoadCharacter()
			end)
		end

		task.delay(2, function()
			if player and player.Parent then
				player:SetAttribute("ZombieRespawnLock", false)
			end
		end)
	end)
end

local function makeConvertedZombie(victimModel)
	local player = getOwningPlayerFromModel(victimModel)

	if player then
		storeConvertedPlayerTemplate(player.UserId, victimModel)
	end

	local oldArchivable = victimModel.Archivable
	victimModel.Archivable = true

	local newZombie = victimModel:Clone()

	victimModel.Archivable = oldArchivable

	if not newZombie then
		return nil
	end

	newZombie.Name = (player and (player.Name .. "_Zombie")) or (victimModel.Name .. "_Zombie")

	removeCharacterScripts(newZombie)
	colorZombieModel(newZombie)
	copyZombieScriptsInto(newZombie)

	newZombie:SetAttribute("ConvertedPlayerZombie", nil)
	newZombie:SetAttribute("ConvertedPlayerUserId", nil)
	newZombie:SetAttribute("ZombieConverting", nil)
	newZombie:SetAttribute("ZombieGrabLocked", nil)
	newZombie:SetAttribute("IsZombie", true)

	local newHumanoid = newZombie:FindFirstChildOfClass("Humanoid")
	local newRoot = getModelRoot(newZombie)

	newZombie.Parent = workspace
	newZombie:PivotTo(victimModel:GetPivot())

	for _, desc in ipairs(newZombie:GetDescendants()) do
		if desc:IsA("BasePart") then
			desc.Anchored = false
			desc.CanCollide = true
			desc.AssemblyLinearVelocity = Vector3.zero
			desc.AssemblyAngularVelocity = Vector3.zero
			pcall(function()
				desc:SetNetworkOwner(nil)
			end)
		end
	end

	if newHumanoid and newRoot then
		newHumanoid.Health = newHumanoid.MaxHealth
		newHumanoid.AutoRotate = false
		newHumanoid.WalkSpeed = 0
		pcall(function()
			newHumanoid.JumpPower = 0
		end)

		local riseTrack, riseAnimObj = playOneShotAnimation(newHumanoid, ZOMBIE_RISE_ANIM_ID)

		task.delay(ZOMBIE_RISE_DURATION, function()
			if newZombie.Parent and newHumanoid.Parent then
				newHumanoid.AutoRotate = true
				newHumanoid.WalkSpeed = WALK_SPEED
			end
		end)

		task.delay(ZOMBIE_RISE_DURATION, function()
			if riseTrack then
				pcall(function()
					riseTrack:Stop(0)
					riseTrack:Destroy()
				end)
			end
			if riseAnimObj then
				riseAnimObj:Destroy()
			end
		end)
	end

	if newHumanoid then
		local diedConn
		diedConn = newHumanoid.Died:Connect(function()
			if diedConn then
				pcall(function()
					diedConn:Disconnect()
				end)
			end

			task.delay(PLAYER_ZOMBIE_CORPSE_TIME, function()
				if newZombie and newZombie.Parent then
					newZombie:Destroy()
				end
			end)
		end)
	end

	if player then
		respawnPlayerCharacterNormally(player)
	end

	return newZombie
end

local function clearConversionSession(victimModel)
	local session = conversionSessions[victimModel]
	if not session then
		return
	end

	session.cancelled = true

	if session.sound then
		pcall(function()
			if session.sound.Parent then
				session.sound:Stop()
				session.sound:Destroy()
			end
		end)
	end

	if session.screamSound then
		pcall(function()
			if session.screamSound.Parent then
				session.screamSound:Stop()
				session.screamSound:Destroy()
			end
		end)
	end

	if session.convertAnim then
		pcall(function()
			session.convertAnim:Stop(0)
			session.convertAnim:Destroy()
		end)
	end

	if session.convertAnimObj then
		pcall(function()
			session.convertAnimObj:Destroy()
		end)
	end

	if session.model and session.model.Parent then
		session.model:SetAttribute("ZombieConverting", nil)
		session.model:SetAttribute("ZombieGrabLocked", false)
	end

	if session.humanoid and session.humanoid.Parent then
		session.humanoid.PlatformStand = session.saved.PlatformStand
		session.humanoid.AutoRotate = session.saved.AutoRotate
		session.humanoid.WalkSpeed = session.saved.WalkSpeed
		pcall(function()
			session.humanoid.JumpPower = session.saved.JumpPower
		end)
		pcall(function()
			session.humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
		end)
	end

	conversionSessions[victimModel] = nil
	convertedModels[victimModel] = nil
end

local function cancelAllConversions()
	for victimModel in pairs(conversionSessions) do
		clearConversionSession(victimModel)
	end
end

local function playConversionSequence(victimModel, victimHumanoid)
	if convertedModels[victimModel] then
		return
	end
	convertedModels[victimModel] = true

	task.spawn(function()
		if not victimModel.Parent or not victimHumanoid.Parent or victimHumanoid.Health <= 0 then
			convertedModels[victimModel] = nil
			return
		end

		local victimRoot = getModelRoot(victimModel)
		if not victimRoot then
			convertedModels[victimModel] = nil
			return
		end

		local victimPlayer = getOwningPlayerFromModel(victimModel)

		local session = {
			model = victimModel,
			humanoid = victimHumanoid,
			saved = {
				PlatformStand = victimHumanoid.PlatformStand,
				AutoRotate = victimHumanoid.AutoRotate,
				WalkSpeed = victimHumanoid.WalkSpeed,
				JumpPower = victimHumanoid.JumpPower,
				Health = victimHumanoid.Health,
			},
			cancelled = false,
			sound = nil,
			screamSound = nil,
			convertAnim = nil,
			convertAnimObj = nil,
		}

		conversionSessions[victimModel] = session

		victimModel:SetAttribute("ZombieConverting", true)
		victimModel:SetAttribute("ZombieGrabLocked", true)

		local convertSound = Instance.new("Sound")
		convertSound.SoundId = CONVERT_SOUND_ID
		convertSound.Volume = 1
		convertSound.RollOffMaxDistance = 80
		convertSound.Parent = victimRoot
		convertSound:Play()

		session.sound = convertSound

		if not victimPlayer then
			session.screamSound = playNpcScream(victimRoot)
		end

		local convertAnim, convertAnimObj = playOneShotAnimation(victimHumanoid, CONVERT_ANIM_ID)
		session.convertAnim = convertAnim
		session.convertAnimObj = convertAnimObj

		victimHumanoid.AutoRotate = false
		victimHumanoid.WalkSpeed = 0
		pcall(function()
			victimHumanoid.JumpPower = 0
		end)

		task.delay(CONVERT_SOUND_DURATION, function()
			if convertSound and convertSound.Parent then
				pcall(function()
					convertSound:Stop()
					convertSound:Destroy()
				end)
			end
		end)

		task.wait(CONVERT_SOUND_DURATION)

		if session.cancelled or not victimModel.Parent or victimHumanoid.Health <= 0 then
			clearConversionSession(victimModel)
			return
		end

		local newZombie = makeConvertedZombie(victimModel)
		if not newZombie then
			clearConversionSession(victimModel)
			return
		end

		-- Kill the original NPC after the conversion finishes.
		if not victimPlayer then
			pcall(function()
				if victimHumanoid and victimHumanoid.Parent and victimHumanoid.Health > 0 then
					victimHumanoid.Health = 0
				end
			end)
		end

		task.delay(HUMAN_CORPSE_CLEANUP_TIME, function()
			if victimModel and victimModel.Parent then
				victimModel:Destroy()
			end
		end)

		if convertAnim then
			pcall(function()
				convertAnim:Stop(0)
				convertAnim:Destroy()
			end)
		end
		if convertAnimObj then
			convertAnimObj:Destroy()
		end

		victimModel:SetAttribute("ZombieConverting", nil)
		victimModel:SetAttribute("ZombieGrabLocked", nil)

		conversionSessions[victimModel] = nil
		convertedModels[victimModel] = nil

		clearCurrentTarget()
		resetAttackState()
		state = "Idle"
		setSpeed(0)
	end)
end

local function beginGrab(targetModel, targetHumanoid)
	if attacking then
		return false
	end

	if time() < nextAttackAt then
		return false
	end

	if not targetModel or not targetHumanoid or targetHumanoid.Health <= 0 then
		return false
	end

	if isZombieModel(targetModel) then
		return false
	end

	if targetModel:GetAttribute("ZombieGrabLocked") == true then
		return false
	end

	if targetModel:GetAttribute("ZombieConverting") == true then
		return false
	end

	local targetRoot = getModelRoot(targetModel)
	if not targetRoot then
		return false
	end

	local holdPart = ensureBiteHold()

	attacking = true
	attackEndsAt = time() + ATTACK_DURATION
	nextAttackAt = time() + ATTACK_COOLDOWN
	state = "Attack"

	targetModel:SetAttribute("ZombieGrabLocked", true)

	setSpeed(0)
	humanoid:MoveTo(root.Position)
	playAttackAnimation()

	local saved = {
		PlatformStand = targetHumanoid.PlatformStand,
		AutoRotate = targetHumanoid.AutoRotate,
		WalkSpeed = targetHumanoid.WalkSpeed,
		JumpPower = targetHumanoid.JumpPower,
		Health = targetHumanoid.Health,
	}

	local collisionSave = {}
	for _, desc in ipairs(targetModel:GetDescendants()) do
		if desc:IsA("BasePart") then
			collisionSave[desc] = desc.CanCollide
			desc.CanCollide = false
			desc.AssemblyLinearVelocity = Vector3.zero
			desc.AssemblyAngularVelocity = Vector3.zero
		end
	end

	targetHumanoid.PlatformStand = true
	targetHumanoid.AutoRotate = false
	targetHumanoid.WalkSpeed = 0
	pcall(function()
		targetHumanoid.JumpPower = 0
	end)

	-- Keep the target locked in the bite position.
	targetRoot.CFrame = holdPart.CFrame * CFrame.new(0, 0, -0.8)

	local weld = Instance.new("WeldConstraint")
	weld.Part0 = holdPart
	weld.Part1 = targetRoot
	weld.Parent = holdPart

	grabbedVictim = {
		model = targetModel,
		humanoid = targetHumanoid,
		root = targetRoot,
		weld = weld,
		partCollisions = collisionSave,
		saved = saved,
	}

	local diedConn
	diedConn = targetHumanoid.Died:Connect(function()
		releaseVictim(false)
		if diedConn then
			pcall(function()
				diedConn:Disconnect()
			end)
		end
	end)

	grabbedVictim.diedConn = diedConn

	local projectedHealth = targetHumanoid.Health - ATTACK_DAMAGE
	if targetHumanoid.Health <= CONVERT_CHECK_THRESHOLD or projectedHealth <= CONVERT_CHECK_THRESHOLD then
		releaseVictim(true)
		resetAttackState()
		clearCurrentTarget()
		state = "Idle"
		setSpeed(0)
		playConversionSequence(targetModel, targetHumanoid)
	else
		targetHumanoid:TakeDamage(ATTACK_DAMAGE)
	end

	return true
end

