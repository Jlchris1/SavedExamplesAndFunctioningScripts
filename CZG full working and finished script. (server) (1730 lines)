local function releaseVictim(keepLock)
	if not grabbedVictim then
		return
	end

	local g = grabbedVictim
	grabbedVictim = nil

	if g.model and g.model.Parent and not keepLock then
		g.model:SetAttribute("ZombieGrabLocked", false)
	end

	if g.player then
		setBackpackHidden(g.player, false)
		g.player:SetAttribute("ZombieConverting", false)
	end

	if g.diedConn and not keepLock then
		pcall(function()
			g.diedConn:Disconnect()
		end)
		victimDeathConnections[g.model] = nil
	end

	if g.weld and g.weld.Parent then
		g.weld:Destroy()
	end

	if g.root and g.root.Parent then
		g.root.AssemblyLinearVelocity = Vector3.zero
		g.root.AssemblyAngularVelocity = Vector3.zero
		if keepLock then
			g.root.Anchored = true
		else
			g.root.Anchored = g.saved.RootAnchored
		end
	end

	if g.humanoid and g.humanoid.Parent then
		if not keepLock then
			g.humanoid.PlatformStand = g.saved.PlatformStand
			g.humanoid.AutoRotate = g.saved.AutoRotate
			g.humanoid.WalkSpeed = g.saved.WalkSpeed
			restoreJumpSettings(g.humanoid, g.saved)
			if g.saved.BreakJointsOnDeath ~= nil then
				pcall(function()
					g.humanoid.BreakJointsOnDeath = g.saved.BreakJointsOnDeath
				end)
			end
			pcall(function()
				g.humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
			end)
		end
	end

	if g.partCollisions and not keepLock then
		for part, oldValue in pairs(g.partCollisions) do
			if part and part.Parent then
				part.CanCollide = oldValue
			end
		end
	end
end

local function ensureBiteHold()
	if biteHold and biteHold.Parent then
		return biteHold
	end

	biteHold = Instance.new("Part")
	biteHold.Name = "BiteHold"
	biteHold.Size = Vector3.new(1, 1, 1)
	biteHold.Transparency = 1
	biteHold.CanCollide = false
	biteHold.CanQuery = false
	biteHold.CanTouch = false
	biteHold.Massless = true
	biteHold.Anchored = false
	biteHold.Parent = zombie
	biteHold.CFrame = root.CFrame * CFrame.new(0, 0.4, -2.0)

	local weld = Instance.new("WeldConstraint")
	weld.Part0 = root
	weld.Part1 = biteHold
	weld.Parent = biteHold

	return biteHold
end

local function respawnZombieAtCFrame(returnCFrame)
	if zombieRefreshQueued then
		return
	end
	zombieRefreshQueued = true

	task.defer(function()
		if not zombie or not zombie.Parent then
			return
		end

		local oldZombie = zombie
		local source = zombieTemplate or zombie

		local oldArchivable = source.Archivable
		source.Archivable = true
		local newZombie = source:Clone()
		source.Archivable = oldArchivable

		if not newZombie then
			return
		end

		newZombie.Parent = workspace
		newZombie:PivotTo(returnCFrame or ORIGINAL_SPAWN_CFRAME)
		newZombie:SetAttribute("IsZombie", true)

		if oldZombie:GetAttribute("ConvertedPlayerZombie") == true then
			newZombie:SetAttribute("ConvertedPlayerZombie", true)
			local uid = oldZombie:GetAttribute("ConvertedPlayerUserId")
			if typeof(uid) == "number" then
				newZombie:SetAttribute("ConvertedPlayerUserId", uid)
			end
		else
			newZombie:SetAttribute("ConvertedPlayerZombie", nil)
			newZombie:SetAttribute("ConvertedPlayerUserId", nil)
		end

		local oldRig = oldZombie:GetAttribute("ConvertedRigType")
		if typeof(oldRig) == "string" then
			newZombie:SetAttribute("ConvertedRigType", oldRig)
		else
			newZombie:SetAttribute("ConvertedRigType", nil)
		end

		newZombie:SetAttribute("ZombieConverting", nil)
		newZombie:SetAttribute("ZombieGrabLocked", nil)

		for _, desc in ipairs(newZombie:GetDescendants()) do
			if desc:IsA("BasePart") then
				desc.Anchored = false
				desc.CanCollide = true
				desc.CanTouch = true
				desc.CanQuery = true
				desc.AssemblyLinearVelocity = Vector3.zero
				desc.AssemblyAngularVelocity = Vector3.zero
				pcall(function()
					desc:SetNetworkOwner(nil)
				end)
			end
		end

		local newHumanoid = newZombie:FindFirstChildOfClass("Humanoid")
		if newHumanoid then
			newHumanoid.Health = newHumanoid.MaxHealth
		end

		task.delay(0.05, function()
			if oldZombie and oldZombie.Parent then
				oldZombie:Destroy()
			end
		end)
	end)
end

local function getActiveConversionCount()
	local count = 0
	for _ in pairs(conversionSessions) do
		count += 1
	end
	return count
end

local function makeConvertedZombie(victimModel, sourceModel)
	local player = getOwningPlayerFromModel(victimModel)
	local victimHumanoid = victimModel:FindFirstChildOfClass("Humanoid")
	local rigTypeName = getRigTypeNameFromHumanoid(victimHumanoid)
	local sourceMaxHealth = 100
	if victimHumanoid then
		sourceMaxHealth = math.max(victimHumanoid.MaxHealth or victimHumanoid.Health or 100, 1)
	end

	local cloneSource = sourceModel or victimModel
	if not cloneSource then
		return nil
	end

	local oldArchivable = cloneSource.Archivable
	cloneSource.Archivable = true
	local newZombie = cloneSource:Clone()
	cloneSource.Archivable = oldArchivable

	if not newZombie then
		return nil
	end

	newZombie.Name = (player and (player.Name .. "_Zombie")) or (victimModel.Name .. "_Zombie")

	removeCharacterScripts(newZombie)
	colorZombieModel(newZombie)

	newZombie:SetAttribute("ConvertedRigType", rigTypeName)
	newZombie:SetAttribute("IsZombie", true)
	newZombie:SetAttribute("ConvertedZombie", true)

	if player then
		newZombie:SetAttribute("ConvertedPlayerZombie", true)
		newZombie:SetAttribute("ConvertedPlayerUserId", player.UserId)
		pcall(function()
			player.CharacterAutoLoads = false
		end)
		player:SetAttribute("ZombieRespawnLock", true)
	else
		newZombie:SetAttribute("ConvertedPlayerZombie", nil)
		newZombie:SetAttribute("ConvertedPlayerUserId", nil)
	end

	local newHumanoid = newZombie:FindFirstChildOfClass("Humanoid")
	if not newHumanoid then
		newHumanoid = Instance.new("Humanoid")
		newHumanoid.Name = "Humanoid"
		newHumanoid.Parent = newZombie
	end

	newHumanoid.MaxHealth = sourceMaxHealth
	newHumanoid.Health = newHumanoid.MaxHealth
	newHumanoid.AutoRotate = false
	newHumanoid.RequiresNeck = false
	newHumanoid.BreakJointsOnDeath = true

	local newRoot = getModelRoot(newZombie)
	if newRoot then
		newZombie.PrimaryPart = newRoot
	end

	newZombie.Parent = workspace
	newZombie:PivotTo(victimModel:GetPivot())

	copyZombieScriptsInto(newZombie)

	for _, desc in ipairs(newZombie:GetDescendants()) do
		if desc:IsA("BasePart") then
			desc.Anchored = false
			desc.CanCollide = true
			desc.CanTouch = true
			desc.CanQuery = true
			desc.AssemblyLinearVelocity = Vector3.zero
			desc.AssemblyAngularVelocity = Vector3.zero
			pcall(function()
				desc:SetNetworkOwner(nil)
			end)
		end
	end

	local riseAnimId = ZOMBIE_RISE_ANIM_ID
	local riseDuration = ZOMBIE_RISE_DURATION
	if rigTypeName == "R6" then
		riseAnimId = R6_CONVERTED_GETUP_ANIM_ID
		riseDuration = R6_CONVERTED_GETUP_DURATION
	end

	local riseTrack, riseAnimObj = playOneShotAnimation(newHumanoid, riseAnimId)

	task.delay(riseDuration, function()
		if newZombie.Parent and newHumanoid.Parent then
			newHumanoid.AutoRotate = true
			newHumanoid.WalkSpeed = WALK_SPEED
		end
	end)

	task.delay(riseDuration, function()
		if riseTrack then
			pcall(function()
				riseTrack:Stop(0)
				riseTrack:Destroy()
			end)
		end
		if riseAnimObj then
			riseAnimObj:Destroy()
		end
	end)

	newHumanoid.Died:Connect(function()
		if newZombie and newZombie.Parent then
			prepareCorpseForCleanup(newZombie)
			cleanupCorpseAfter(newZombie, CONVERTED_CORPSE_CLEANUP_TIME)
		end
	end)

	return newZombie
end

local function cancelConversionSession(victimModel)
	local session = conversionSessions[victimModel]
	if not session then
		return
	end

	session.cancelled = true

	if session.player then
		setBackpackHidden(session.player, false)
	end

	if victimDeathConnections[victimModel] then
		pcall(function()
			victimDeathConnections[victimModel]:Disconnect()
		end)
		victimDeathConnections[victimModel] = nil
	end

	if session.diedConn then
		pcall(function()
			session.diedConn:Disconnect()
		end)
	end

	if session.sound and session.sound.Parent then
		pcall(function()
			session.sound:Stop()
			session.sound:Destroy()
		end)
	end

	if session.screamSound and session.screamSound.Parent then
		pcall(function()
			session.screamSound:Stop()
			session.screamSound:Destroy()
		end)
	end

	if session.convertAnim then
		pcall(function()
			session.convertAnim:Stop(0)
			session.convertAnim:Destroy()
		end)
	end

	if session.convertAnimObj then
		pcall(function()
			session.convertAnimObj:Destroy()
		end)
	end

	if session.conversionSource then
		pcall(function()
			if session.conversionSource.Parent then
				session.conversionSource:Destroy()
			end
		end)
	end

	if session.model and session.model.Parent then
		session.model:SetAttribute("ZombieConverting", nil)
		session.model:SetAttribute("ZombieGrabLocked", false)
	end

	if session.root and session.root.Parent then
		session.root.Anchored = session.saved.RootAnchored
		session.root.AssemblyLinearVelocity = Vector3.zero
		session.root.AssemblyAngularVelocity = Vector3.zero
	end

	if session.humanoid and session.humanoid.Parent then
		session.humanoid.PlatformStand = session.saved.PlatformStand
		session.humanoid.AutoRotate = session.saved.AutoRotate
		session.humanoid.WalkSpeed = session.saved.WalkSpeed
		restoreJumpSettings(session.humanoid, session.saved)
		if session.saved.BreakJointsOnDeath ~= nil then
			pcall(function()
				session.humanoid.BreakJointsOnDeath = session.saved.BreakJointsOnDeath
			end)
		end
		pcall(function()
			session.humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
		end)
	end

	if session.partCollisions then
		for part, oldValue in pairs(session.partCollisions) do
			if part and part.Parent then
				part.CanCollide = oldValue
			end
		end
	end

	conversionSessions[victimModel] = nil
end

local function playConversionSequence(victimModel, victimHumanoid)
	local victimRoot = getModelRoot(victimModel)
	if not victimRoot or not victimHumanoid then
		return
	end

	local victimPlayer = getOwningPlayerFromModel(victimModel)

	local session = {
		model = victimModel,
		humanoid = victimHumanoid,
		root = victimRoot,
		player = victimPlayer,
		saved = {
			PlatformStand = victimHumanoid.PlatformStand,
			AutoRotate = victimHumanoid.AutoRotate,
			WalkSpeed = victimHumanoid.WalkSpeed,
			JumpPower = victimHumanoid.JumpPower,
			JumpHeight = victimHumanoid.JumpHeight,
			UseJumpPower = victimHumanoid.UseJumpPower,
			Health = victimHumanoid.Health,
			RootAnchored = victimRoot.Anchored,
			BreakJointsOnDeath = victimHumanoid.BreakJointsOnDeath,
		},
		cancelled = false,
		victimDiedDuringConversion = false,
		sound = nil,
		screamSound = nil,
		convertAnim = nil,
		convertAnimObj = nil,
		partCollisions = nil,
		diedConn = nil,
		conversionSource = nil,
	}

	conversionSessions[victimModel] = session

	victimModel:SetAttribute("ZombieConverting", true)
	victimModel:SetAttribute("ZombieGrabLocked", true)

	if victimPlayer then
		setBackpackHidden(victimPlayer, true)
		victimPlayer:SetAttribute("ZombieConverting", true)
	end

	local convertSource = cloneModelForConversion(victimModel)
	session.conversionSource = convertSource

	local convertSound = Instance.new("Sound")
	convertSound.SoundId = CONVERT_SOUND_ID
	convertSound.Volume = 1
	convertSound.RollOffMaxDistance = 80
	convertSound.Parent = victimRoot
	convertSound:Play()
	session.sound = convertSound

	if not victimPlayer then
		session.screamSound = playNpcScream(victimRoot)
	end

	local convertAnim, convertAnimObj = playConversionAnimation(victimHumanoid)
	session.convertAnim = convertAnim
	session.convertAnimObj = convertAnimObj

	victimHumanoid.AutoRotate = false
	victimHumanoid.WalkSpeed = 0
	victimHumanoid.BreakJointsOnDeath = true
	disableJump(victimHumanoid)

	session.diedConn = victimHumanoid.Died:Connect(function()
		session.victimDiedDuringConversion = true
		if session.model and session.model.Parent then
			prepareCorpseForCleanup(session.model)
			session.model:SetAttribute("ZombieConverting", true)
			session.model:SetAttribute("ZombieGrabLocked", true)
		end
	end)

	task.delay(CONVERT_SOUND_DURATION, function()
		if convertSound and convertSound.Parent then
			pcall(function()
				convertSound:Stop()
				convertSound:Destroy()
			end)
		end
	end)

	task.wait(CONVERT_SOUND_DURATION)

	if session.cancelled or not victimModel.Parent then
		cancelConversionSession(victimModel)
		return
	end

	local newZombie = makeConvertedZombie(victimModel, session.conversionSource)
	if not newZombie then
		cancelConversionSession(victimModel)
		return
	end

	if victimPlayer then
		if victimHumanoid and victimHumanoid.Parent and victimHumanoid.Health > 0 then
			pcall(function()
				victimHumanoid.Health = 0
			end)
		end
		task.delay(HUMAN_CORPSE_CLEANUP_TIME, function()
			if victimModel and victimModel.Parent then
				victimModel:Destroy()
			end
		end)
	else
		if victimHumanoid and victimHumanoid.Parent then
			pcall(function()
				victimHumanoid.Health = victimHumanoid.MaxHealth
				victimHumanoid.PlatformStand = false
				victimHumanoid.AutoRotate = true
				victimHumanoid.WalkSpeed = 0
				restoreJumpSettings(victimHumanoid, session.saved)
				victimHumanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
			end)
		end

		task.defer(function()
			if victimModel and victimModel.Parent then
				victimModel:Destroy()
			end
		end)
	end

	if convertAnim then
		pcall(function()
			convertAnim:Stop(0)
			convertAnim:Destroy()
		end)
	end
	if convertAnimObj then
		convertAnimObj:Destroy()
	end

	if session.conversionSource then
		pcall(function()
			if session.conversionSource.Parent then
				session.conversionSource:Destroy()
			end
		end)
	end

	cancelConversionSession(victimModel)

	clearCurrentTarget()
	resetAttackState()
	state = "Idle"
	setSpeed(0)
	if movementAnimController then
		movementAnimController:setState("Idle")
	end
end

local function beginGrab(targetModel, targetHumanoid)
	if attacking then
		return false
	end

	if time() < nextAttackAt then
		return false
	end

	if not targetModel or not targetHumanoid or targetHumanoid.Health <= 0 then
		return false
	end

	if isZombieModel(targetModel) or isConvertingModel(targetModel) then
		return false
	end

	if targetModel:GetAttribute("ZombieGrabLocked") == true then
		return false
	end

	local targetRoot = getModelRoot(targetModel)
	if not targetRoot then
		return false
	end

	local targetPlayer = getOwningPlayerFromModel(targetModel)
	local holdPart = ensureBiteHold()

	attacking = true
	attackEndsAt = time() + ATTACK_DURATION
	nextAttackAt = time() + ATTACK_COOLDOWN
	state = "Attack"

	targetModel:SetAttribute("ZombieGrabLocked", true)
	if targetPlayer then
		setBackpackHidden(targetPlayer, true)
		targetPlayer:SetAttribute("ZombieConverting", true)
	end

	setSpeed(0)
	humanoid:MoveTo(root.Position)
	playAttackAnimation()

	local restoredSpeed = getHistoricalSpeed(targetModel, SPEED_RESTORE_OFFSET, targetHumanoid.WalkSpeed)

	local saved = {
		PlatformStand = targetHumanoid.PlatformStand,
		AutoRotate = targetHumanoid.AutoRotate,
		WalkSpeed = restoredSpeed,
		JumpPower = targetHumanoid.JumpPower,
		JumpHeight = targetHumanoid.JumpHeight,
		UseJumpPower = targetHumanoid.UseJumpPower,
		Health = targetHumanoid.Health,
		RootAnchored = targetRoot.Anchored,
		BreakJointsOnDeath = targetHumanoid.BreakJointsOnDeath,
	}

	local collisionSave = {}
	for _, desc in ipairs(targetModel:GetDescendants()) do
		if desc:IsA("BasePart") then
			collisionSave[desc] = desc.CanCollide
			desc.CanCollide = false
			desc.AssemblyLinearVelocity = Vector3.zero
			desc.AssemblyAngularVelocity = Vector3.zero
		end
	end

	targetHumanoid.PlatformStand = true
	targetHumanoid.AutoRotate = false
	targetHumanoid.WalkSpeed = 0
	targetHumanoid.BreakJointsOnDeath = true
	disableJump(targetHumanoid)

	targetRoot.CFrame = holdPart.CFrame * CFrame.new(0, 0, -0.8)

	local weld = Instance.new("WeldConstraint")
	weld.Part0 = holdPart
	weld.Part1 = targetRoot
	weld.Parent = holdPart

	grabbedVictim = {
		model = targetModel,
		humanoid = targetHumanoid,
		root = targetRoot,
		player = targetPlayer,
		weld = weld,
		partCollisions = collisionSave,
		saved = saved,
	}

	local diedConn
	diedConn = targetHumanoid.Died:Connect(function()
		if targetModel and targetModel.Parent and targetModel:GetAttribute("ZombieConverting") == true then
			if targetRoot and targetRoot.Parent then
				targetRoot.Anchored = false
				targetRoot.AssemblyLinearVelocity = Vector3.zero
				targetRoot.AssemblyAngularVelocity = Vector3.zero
			end
			prepareCorpseForCleanup(targetModel)
			targetModel:SetAttribute("ZombieGrabLocked", true)
			return
		end

		releaseVictim(false)
		if diedConn then
			pcall(function()
				diedConn:Disconnect()
			end)
		end
		victimDeathConnections[targetModel] = nil
	end)

	grabbedVictim.diedConn = diedConn
	victimDeathConnections[targetModel] = diedConn

	local projectedHealth = targetHumanoid.Health - ATTACK_DAMAGE
	if targetHumanoid.Health <= CONVERT_CHECK_THRESHOLD or projectedHealth <= CONVERT_CHECK_THRESHOLD then
		releaseVictim(true)
		resetAttackState()
		clearCurrentTarget()
		state = "Idle"
		setSpeed(0)
		playConversionSequence(targetModel, targetHumanoid)
	else
		targetHumanoid:TakeDamage(ATTACK_DAMAGE)
	end

	return true
end

local function queueZombieRespawn(returnCFrame, waitForConversion)
	if zombieRespawnQueued then
		return
	end

	zombieRespawnQueued = true
	zombieDeathPivot = returnCFrame or ORIGINAL_SPAWN_CFRAME
	zombieDeathAt = time()

	task.spawn(function()
		while zombieRespawnQueued do
			local elapsed = time() - zombieDeathAt
			local activeConversions = getActiveConversionCount()

			if waitForConversion then
				if activeConversions == 0 and not grabbedVictim then
					break
				end
			end

			if elapsed >= ZOMBIE_RESPAWN_TIME then
				break
			end

			task.wait(0.1)
		end

		if zombieRespawnQueued then
			respawnZombieAtCFrame(zombieDeathPivot)
			zombieRespawnQueued = false
		end
	end)
end

--////////////////////////////////////////////////////////////
-- TOUCH ATTACKS
--////////////////////////////////////////////////////////////
local function tryTouchAttackFromHit(hit)
	if zombieDead then
		return
	end

	if not hit or not hit.Parent then
		return
	end

	local model = hit:FindFirstAncestorOfClass("Model")
	if not model or model == zombie then
		return
	end

	if isZombieModel(model) or isConvertingModel(model) then
		return
	end

	local targetHumanoid = model:FindFirstChildOfClass("Humanoid")
	local targetRoot = getModelRoot(model)
	if not targetHumanoid or not targetRoot or targetHumanoid.Health <= 0 then
		return
	end

	if model:GetAttribute("ZombieGrabLocked") == true then
		return
	end

	local now = time()
	local cooldownUntil = touchAttackCooldowns[model]
	if cooldownUntil and now < cooldownUntil then
		return
	end
	touchAttackCooldowns[model] = now + ATTACK_COOLDOWN

	currentTargetModel = model
	currentTargetHumanoid = targetHumanoid
	currentTargetPos = targetRoot.Position
	currentTargetKind = "touch"
	currentTargetMemoryUntil = math.max(currentTargetMemoryUntil, now + 2)
	lastHeardAt = now

	beginGrab(model, targetHumanoid)
end

local function hookZombieTouchPart(part)
	if not part or not part:IsA("BasePart") then
		return
	end

	if touchConnections[part] then
		return
	end

	part.CanTouch = true
	touchConnections[part] = part.Touched:Connect(tryTouchAttackFromHit)
end

for _, desc in ipairs(zombie:GetDescendants()) do
	if desc:IsA("BasePart") then
		hookZombieTouchPart(desc)
	end
end

zombie.DescendantAdded:Connect(function(obj)
	if obj:IsA("BasePart") then
		hookZombieTouchPart(obj)
	end
end)

--////////////////////////////////////////////////////////////
-- TARGETING
--////////////////////////////////////////////////////////////
local function startLookAround(now)
	state = "Look"
	clearCurrentTarget()
	currentTargetEndsAt = now + LOOK_AROUND_TIME
	wanderGoal = nil
	setSpeed(0)
end

local function startWander(now)
	state = "Wander"
	clearCurrentTarget()
	setSpeed(WALK_SPEED)

	local angle = math.random() * math.pi * 2
	local dist = math.random(WANDER_MIN_DISTANCE, WANDER_MAX_DISTANCE)
	local offset = Vector3.new(math.cos(angle) * dist, 0, math.sin(angle) * dist)

	wanderGoal = root.Position + offset
	currentTargetPos = wanderGoal
end

local function beginIdleWait(now)
	state = "Idle"
	setSpeed(0)
	wanderGoal = nil
	currentTargetPos = nil
	nextWanderAt = now + math.random(WANDER_MIN_WAIT, WANDER_MAX_WAIT)
end

local function tryAttackCurrentTarget()
	if not currentTargetHumanoid or not currentTargetModel then
		return false
	end

	if isZombieModel(currentTargetModel) or isConvertingModel(currentTargetModel) then
		return false
	end

	if currentTargetModel:GetAttribute("ZombieGrabLocked") == true then
		return false
	end

	local targetRoot = getModelRoot(currentTargetModel)
	if not targetRoot then
		return false
	end

	local dist = (root.Position - targetRoot.Position).Magnitude
	if dist > ATTACK_RANGE then
		return false
	end

	return beginGrab(currentTargetModel, currentTargetHumanoid)
end

local function pullBestZombieSenseEvent()
	local ev = ZombieSense.PullBestEvent(zombie)
	if not ev then
		return nil
	end

	local dist = ev.dist
	if dist == nil and ev.pos then
		dist = (root.Position - ev.pos).Magnitude
	end

	if not dist then
		return nil
	end

	if dist > (ev.alertRadius or math.huge) then
		return nil
	end

	return ev
end

--////////////////////////////////////////////////////////////
-- DEATH
--////////////////////////////////////////////////////////////
humanoid.Died:Connect(function()
	zombieDead = true
	zombieDeathPivot = zombie:GetPivot()
	zombieDeathAt = time()

	ZombieSense.UnregisterZombie(zombie)

	if zombie:GetAttribute("ConvertedZombie") == true or zombie:GetAttribute("ConvertedPlayerZombie") == true then
		prepareCorpseForCleanup(zombie)
		cleanupCorpseAfter(zombie, CONVERTED_CORPSE_CLEANUP_TIME)
		return
	end

	if grabbedVictim and grabbedVictim.model and grabbedVictim.humanoid then
		local g = grabbedVictim
		releaseVictim(true)
		playConversionSequence(g.model, g.humanoid)
	end

	local waitForConversion = (getActiveConversionCount() > 0) or (grabbedVictim ~= nil)
	queueZombieRespawn(zombieDeathPivot, waitForConversion)

	math.randomseed(tick())
	clearParts(zombie, CONVERTING_CORPSE_CLEANUP_TIME)
end)

--////////////////////////////////////////////////////////////
-- MAIN LOOP
--////////////////////////////////////////////////////////////
humanoid.WalkSpeed = WALK_SPEED
humanoid.AutoRotate = true
nextWanderAt = time() + math.random(WANDER_MIN_WAIT, WANDER_MAX_WAIT)

while zombie.Parent do
	local now = time()

	if zombieDead then
		if movementAnimController then
			movementAnimController:setState("Idle")
		end
		task.wait(0.2)
	else
		if attacking and now >= attackEndsAt then
			resetAttackState()
		end

		if grabbedVictim then
			state = "Attack"
		end

		if not grabbedVictim then
			local bestEvent = pullBestZombieSenseEvent()

			if bestEvent then
				currentTargetPos = bestEvent.pos
				currentTargetModel = bestEvent.model
				currentTargetHumanoid = bestEvent.humanoid
				currentTargetKind = bestEvent.kind
				currentTargetMemoryUntil = math.max(currentTargetMemoryUntil, bestEvent.memoryUntil or now)
				lastHeardAt = now
				wanderGoal = nil

				if bestEvent.isTrigger or (bestEvent.dist and bestEvent.triggerRadius and bestEvent.dist <= bestEvent.triggerRadius) then
					state = "Run"
					setSpeed(RUN_SPEED)
				else
					state = "Alert"
					setSpeed(ALERT_SPEED)
				end
			elseif now > currentTargetMemoryUntil then
				if state ~= "Idle" then
					beginIdleWait(now)
				elseif now >= nextWanderAt then
					startWander(now)
				end
			end
		end

		if state == "Attack" then
			setSpeed(0)
			humanoid:MoveTo(root.Position)

			if now >= attackEndsAt then
				releaseVictim(false)
				attacking = false

				if currentTargetModel and currentTargetModel.Parent and currentTargetHumanoid and currentTargetHumanoid.Health > 0 then
					local dist = currentTargetPos and (root.Position - currentTargetPos).Magnitude or math.huge
					if dist <= 12 then
						state = "Run"
						setSpeed(RUN_SPEED)
					else
						state = "Alert"
						setSpeed(ALERT_SPEED)
					end
				else
					beginIdleWait(now)
				end
			end

		elseif state == "Run" or state == "Alert" then
			if currentTargetPos then
				humanoid:MoveTo(currentTargetPos)

				local distToTarget = (root.Position - currentTargetPos).Magnitude
				local sourceStillFresh = (now - lastHeardAt) <= 1.5

				if not grabbedVictim then
					if currentTargetHumanoid and currentTargetHumanoid.Health > 0 and distToTarget <= ATTACK_RANGE then
						if tryAttackCurrentTarget() then
							task.wait(0.05)
							if movementAnimController then
								movementAnimController:setState(state)
							end
							task.wait(0.15)
							continue
						end
					end
				end

				if distToTarget <= ARRIVE_DISTANCE and not sourceStillFresh and now > currentTargetMemoryUntil then
					startLookAround(now)
				end
			else
				if now > currentTargetMemoryUntil then
					beginIdleWait(now)
				end
			end

			if state == "Run" and now >= currentTargetMemoryUntil then
				state = "Alert"
				setSpeed(ALERT_SPEED)
			end

		elseif state == "Look" then
			setSpeed(0)
			humanoid:MoveTo(root.Position)

			if now >= currentTargetEndsAt then
				beginIdleWait(now)
			end

		elseif state == "Wander" then
			setSpeed(WALK_SPEED)

			if wanderGoal then
				humanoid:MoveTo(wanderGoal)

				local reached = (root.Position - wanderGoal).Magnitude <= ARRIVE_DISTANCE
				if reached then
					beginIdleWait(now)
				end
			else
				beginIdleWait(now)
			end
		end

		if movementAnimController then
			movementAnimController:setState(state)
		end

		task.wait(0.2)
	end
end
